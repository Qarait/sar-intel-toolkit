{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SAR Tracks",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "track_id",
      "type",
      "first_seen",
      "last_seen",
      "first_frame",
      "last_frame",
      "hits",
      "lat",
      "lon",
      "max_confidence",
      "mean_confidence",
      "representative_bbox"
    ],
    "properties": {
      "track_id": {
        "type": "integer",
        "minimum": 1
      },
      "type": {
        "type": "string",
        "const": "possible_person_track"
      },
      "first_seen": {
        "type": "string"
      },
      "last_seen": {
        "type": "string"
      },
      "first_frame": {
        "type": "integer",
        "minimum": 0
      },
      "last_frame": {
        "type": "integer",
        "minimum": 0
      },
      "hits": {
        "type": "integer",
        "minimum": 1
      },
      "lat": {
        "type": "number"
      },
      "lon": {
        "type": "number"
      },
      "max_confidence": {
        "type": "number",
        "minimum": 0.0,
        "maximum": 1.0
      },
      "mean_confidence": {
        "type": "number",
        "minimum": 0.0,
        "maximum": 1.0
      },
      "representative_bbox": {
        "type": "array",
        "items": {
          "type": "number"
        },
        "minItems": 4,
        "maxItems": 4
      },
      "duration_seconds": {
        "type": "number",
        "minimum": 0.0
      },
      "detection_density": {
        "type": "number",
        "minimum": 0.0,
        "maximum": 1.0
      },
      "track_score": {
        "type": "number",
        "minimum": 0.0,
        "maximum": 1.0
      },
      "track_class": {
        "type": "string",
        "enum": [
          "high_confidence_person",
          "possible_person",
          "marginal_person"
        ]
      },
      "motion_model": {
        "type": "string",
        "enum": [
          "kalman"
        ]
      },
      "missed_frames": {
        "type": "integer",
        "minimum": 0
      },
      "max_consecutive_misses": {
        "type": "integer",
        "minimum": 0
      }
    },
    "additionalProperties": false
  }
}